# EditorConfig — InLay
# https://editorconfig.org · https://learn.microsoft.com/dotnet/fundamentals/code-analysis/code-style-rule-options
root = true

##############################
# All files
##############################
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

##############################
# Web / data / doc files — 2-space
##############################
[*.{json,json5,yml,yaml,xml,csproj,props,targets,manifest,config,ps1}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false   # trailing double-space is a hard line break

##############################
# C#
##############################
[*.cs]
indent_size = 4
max_line_length = 120

# --- Language conventions ---
csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# var
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion

# Modern C# idioms
csharp_prefer_braces = true:warning
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_prefer_null_check_over_type_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_style_prefer_index_operator = true:suggestion
csharp_style_prefer_range_operator = true:suggestion
csharp_style_deconstructed_variable_declaration = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_readonly_field = true:warning

# 'this.' — never
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Accessibility modifiers always
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# --- Naming rules ---
# Interfaces: IPascalCase
dotnet_naming_rule.interfaces_should_be_prefixed_i.severity = warning
dotnet_naming_rule.interfaces_should_be_prefixed_i.symbols = interface_symbol
dotnet_naming_rule.interfaces_should_be_prefixed_i.style = ipascal_style
dotnet_naming_symbols.interface_symbol.applicable_kinds = interface
dotnet_naming_style.ipascal_style.capitalization = pascal_case
dotnet_naming_style.ipascal_style.required_prefix = I

# Type parameters: TPascalCase
dotnet_naming_rule.type_parameters_should_be_prefixed_t.severity = warning
dotnet_naming_rule.type_parameters_should_be_prefixed_t.symbols = type_parameter_symbol
dotnet_naming_rule.type_parameters_should_be_prefixed_t.style = tpascal_style
dotnet_naming_symbols.type_parameter_symbol.applicable_kinds = type_parameter
dotnet_naming_style.tpascal_style.capitalization = pascal_case
dotnet_naming_style.tpascal_style.required_prefix = T

# Types & members: PascalCase
dotnet_naming_rule.types_and_members_pascal.severity = warning
dotnet_naming_rule.types_and_members_pascal.symbols = types_and_members_symbol
dotnet_naming_rule.types_and_members_pascal.style = pascal_style
dotnet_naming_symbols.types_and_members_symbol.applicable_kinds = class,struct,enum,property,method,event,delegate,local_function
dotnet_naming_style.pascal_style.capitalization = pascal_case

# Constants & static readonly: PascalCase
dotnet_naming_rule.constants_pascal.severity = warning
dotnet_naming_rule.constants_pascal.symbols = constant_symbol
dotnet_naming_rule.constants_pascal.style = pascal_style
dotnet_naming_symbols.constant_symbol.applicable_kinds = field
dotnet_naming_symbols.constant_symbol.required_modifiers = const

# Private/internal instance fields: _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_field_symbol
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_style
dotnet_naming_symbols.private_field_symbol.applicable_kinds = field
dotnet_naming_symbols.private_field_symbol.applicable_accessibilities = private,internal,private_protected
dotnet_naming_style.underscore_camel_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_style.required_prefix = _

# Parameters & locals: camelCase
dotnet_naming_rule.parameters_camel.severity = suggestion
dotnet_naming_rule.parameters_camel.symbols = parameter_local_symbol
dotnet_naming_rule.parameters_camel.style = camel_style
dotnet_naming_symbols.parameter_local_symbol.applicable_kinds = parameter,local
dotnet_naming_style.camel_style.capitalization = camel_case

# --- Analyzer noise tuning ---
# CA2007: ConfigureAwait not needed in a WPF app with a single UI SynchronizationContext
dotnet_diagnostic.CA2007.severity = none
# CA1848: LoggerMessage delegates — a hot-path perf rule; InLay logs at low frequency, so the
# source-generated-delegate boilerplate is not worth it.
dotnet_diagnostic.CA1848.severity = none

##############################
# Generated / designer files
##############################
[*.{g,g.i,Designer}.cs]
generated_code = true

[*.xaml.cs]
# code-behind: keep analyzers, but these are partial with generated halves
dotnet_diagnostic.CA1812.severity = none
