<ui:FluentWindow
    x:Class="InLay.App.Settings.SettingsWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="InLay Settings"
    Width="520"
    Height="340"
    MinWidth="420"
    MinHeight="260"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="InLay Settings" />

        <StackPanel Grid.Row="1" Margin="24,8,24,24">
            <TextBlock Margin="0,0,0,16"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Text="General" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontWeight="Medium" Text="Start with Windows" />
                    <TextBlock Margin="0,2,0,0"
                               FontSize="12"
                               Opacity="0.7"
                               Text="Launch InLay automatically when you sign in." />
                </StackPanel>

                <ui:ToggleSwitch Grid.Column="1"
                                 VerticalAlignment="Center"
                                 IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
